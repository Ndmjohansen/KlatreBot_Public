# Required
DISCORD_KEY=your_discord_bot_token_here
OPENAI_KEY=sk-your_openai_key_here
DISCORD_MAIN_CHANNEL_ID=0
DISCORD_SANDBOX_CHANNEL_ID=0
ADMIN_USER_ID=0

# Optional (defaults shown)
MODEL=gpt-5.4
SOUL_PATH=./SOUL.MD
DB_PATH=./klatrebot_v2.db

TIMEZONE=Europe/Copenhagen
KLATRETID_DAYS=[0,3]
KLATRETID_POST_HOUR=17
KLATRETID_START_HOUR=20

GPT_RECENT_MESSAGE_COUNT=25
RATE_LIMIT_PER_USER_PER_HOUR=30
LOG_LEVEL=INFO

# Read-only HTTP API exposed to Hermes (LAN only). Bind 0.0.0.0 + UFW rule, or
# bind directly to the Pi's LAN IP. Bearer auth required.
API_ENABLED=false
API_HOST=0.0.0.0
API_PORT=8765
API_TOKEN=
API_QUERY_TIMEOUT_SECONDS=5.0
API_MAX_ROWS=500

# Embeddings (semantic search for Hermes)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDINGS_ENABLED=true

# Router + Hermes (Phase 1: classifier on, Hermes disabled)
CLASSIFIER_MODEL=gpt-5.4-nano
CLASSIFIER_TIMEOUT_SECONDS=3.0
HERMES_ENABLED=false
HERMES_URL=http://localhost:8642
HERMES_TOKEN=
HERMES_MODEL=hermes-agent
HERMES_TIMEOUT_SECONDS=25.0
