# Required
DISCORD_KEY=your_discord_bot_token_here
OPENAI_KEY=sk-your_openai_key_here
DISCORD_MAIN_CHANNEL_ID=0
DISCORD_SANDBOX_CHANNEL_ID=0
ADMIN_USER_ID=0

# Optional (defaults shown)
MODEL=gpt-5.4
SOUL_PATH=./SOUL.MD
DB_PATH=./klatrebot_v2.db
USER_ALIASES_CONFIG_PATH=

TIMEZONE=Europe/Copenhagen
KLATRETID_DAYS=[0,3]
KLATRETID_POST_HOUR=17
KLATRETID_START_HOUR=20

GPT_RECENT_MESSAGE_COUNT=25
RATE_LIMIT_PER_USER_PER_HOUR=30
LOG_LEVEL=INFO

# Durable memory
MEMORY_ENABLED=false
MEMORY_ACTIVE_RUN_NAME=production
MEMORY_COMPILER_MODEL=gpt-5.4-mini

# Rolling production memory compiler
MEMORY_ROLLING_ENABLED=false
MEMORY_ROLLING_RUN_NAME=production
MEMORY_ROLLING_SETTLE_MINUTES=45
MEMORY_ROLLING_TAIL_BUFFER_MINUTES=180
MEMORY_ROLLING_INITIAL_LOOKBACK_HOURS=24
MEMORY_ROLLING_CONCURRENCY=2
